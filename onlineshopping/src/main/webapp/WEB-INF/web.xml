<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
  <display-name>Online Shopping - Enterprise App</display-name>

  <listener>
    <listener-class>com.sun.xml.ws.transport.http.servlet.WSServletContextListener</listener-class>
  </listener>

  <!-- ===== Servlets ===== -->
  <servlet>
    <servlet-name>SetupServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.SetupServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.LoginServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.LogoutServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>HelloServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.HelloServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ProductsServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.ProductsServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AboutServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.AboutServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>ContactServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.ContactServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>OrderServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.OrderServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>CartServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.CartServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>AdminReportServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.AdminReportServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>InvoicePdfServlet</servlet-name>
    <servlet-class>com.tareg.onlineshopping.InvoicePdfServlet</servlet-class>
  </servlet>

  <servlet>
    <servlet-name>MetroSoapServlet</servlet-name>
    <servlet-class>com.sun.xml.ws.transport.http.servlet.WSServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <!-- ===== Mappings ===== -->
  <servlet-mapping>
    <servlet-name>SetupServlet</servlet-name>
    <url-pattern>/setup</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>HelloServlet</servlet-name>
    <url-pattern>/hello</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ProductsServlet</servlet-name>
    <url-pattern>/products</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AboutServlet</servlet-name>
    <url-pattern>/about</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ContactServlet</servlet-name>
    <url-pattern>/contact</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>OrderServlet</servlet-name>
    <url-pattern>/orders</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>CartServlet</servlet-name>
    <url-pattern>/cart</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>AdminReportServlet</servlet-name>
    <url-pattern>/reports</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>InvoicePdfServlet</servlet-name>
    <url-pattern>/invoice</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>MetroSoapServlet</servlet-name>
    <url-pattern>/product-catalog</url-pattern>
  </servlet-mapping>

  <!-- Default page -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

</web-app>
